# ──────────────────────────────────────────────
# VLSM Calculator — .gitignore
# ──────────────────────────────────────────────

# Node.js (if ever adding build tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# Logs
*.log
*.tmp
*.temp

# Generated export files (user downloads, not source code)
exports/*.txt
exports/*.xls
exports/*.csv

# Environment files
.env
.env.local
.env.*.local

# Build output (future use)
dist/
build/
out/

# Coverage reports (future use)
coverage/
.nyc_output/
